# SHEtoken Pipeline — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it contains secret keys.
#
# cp .env.example .env

# ── Google Sheets (required for --sheets flag) ────────────────────
#
# Step 1: Create a Google Sheet at sheets.google.com
#         Copy the ID from the URL:
#         https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
#
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Step 2: Create a Service Account at console.cloud.google.com
#         Enable: Google Sheets API + Google Drive API
#         Create credentials → Service Account → download JSON key
#         Share your Google Sheet with the client_email in the JSON (Editor access)
#
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/your/service_account.json

# ── UNESCO API (optional — improves education data) ───────────────
#
# Free key — register at: https://apidata.uis.unesco.org/
# Without this key, education data falls back to World Bank only.
#
UNESCO_API_KEY=your_unesco_api_key_here

# ── Pipeline settings (optional) ─────────────────────────────────
#
BASELINE_YEAR=2025
