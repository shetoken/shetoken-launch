{
  "redirects": [
    { "source": "/wei", "destination": "/dashboard", "statusCode": 301 },
    { "source": "/wei/:path*", "destination": "/dashboard", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/country/:iso", "destination": "/country/:iso.html" },
    { "source": "/index-landscape", "destination": "/index-landscape.html" },
    { "source": "/methodology", "destination": "/methodology.html" },
    { "source": "/whitepaper", "destination": "/whitepaper.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/why-back-she", "destination": "/why-back-she.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/pull-feeds", "schedule": "0 7 * * *" }
  ]
}
